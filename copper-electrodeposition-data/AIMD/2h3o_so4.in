@SET MD_SAVE_FREQ  1
@SET LA 11.5400000000288
@SET LB 9.99399999995988
@SET LC 7.73657729
@SET ALPHA 90.0
@SET BETA 90.0
@SET GAMMA 90.0
@SET RTEMP 298
@SET PREFIX 2h3o_so4
@SET NSTEPS 10000
@SET TSTEP 0.5
@SET CP2K_HOME /usr/local/

&GLOBAL
 PRINT_LEVEL medium
 PROJECT ${PREFIX}
 RUN_TYPE MD
 WALLTIME 47:00:00
&END GLOBAL

&MOTION
 &PRINT
  &VELOCITIES
   FILENAME ./${PREFIX}.${RTEMP}K
   FORMAT XYZ
   &EACH
     MD ${MD_SAVE_FREQ}
   &END EACH
  &END VELOCITIES
  &TRAJECTORY
   FILENAME ./${PREFIX}.${RTEMP}K
   FORMAT XYZ
   &EACH
     MD ${MD_SAVE_FREQ}
   &END EACH
  &END TRAJECTORY
 &END PRINT

 &MD
  &THERMOSTAT
   REGION MASSIVE
   TYPE CSVR
   &CSVR
    TIMECON 300.0
   &END CSVR
  &END THERMOSTAT
  ENSEMBLE NVT
  STEPS 200000
  TIMESTEP 0.5
  TEMPERATURE 300.0
 &END MD

&END MOTION

&FORCE_EVAL
 METHOD Quickstep
 &DFT
 CHARGE 0
  MULTIPLICITY 1
  BASIS_SET_FILE_NAME /global/homes/s/scorreal/CP2Kdata/BASIS_MOLOPT
  POTENTIAL_FILE_NAME /global/homes/s/scorreal/CP2Kdata/GTH_POTENTIALS

    &MGRID
       ! PW cutoff ... depends on the element (basis) too small cutoffs lead to the eggbox effect.
       ! certain calculations (e.g. geometry optimization, vibrational frequencies,
       ! NPT and cell optimizations, need higher cutoffs)
       CUTOFF [Ry] 600
       NGRIDS 5
       REL_CUTOFF 60
    &END
  &QS
       ! use the GPW method (i.e. pseudopotential based calculations with the Gaussian and Plane Waves scheme).
       METHOD GPW
       ! default threshold for numerics ~ roughly numerical accuracy of the total energy per electron,
       ! sets reasonable values for all other thresholds.
       EPS_DEFAULT 1.0E-10
       ! used for MD, the method used to generate the initial guess.
       EXTRAPOLATION ASPC
  &END QS
  &POISSON
   PERIODIC XYZ
   POISSON_SOLVER PERIODIC
  &END POISSON
  &SCF
          SCF_GUESS ATOMIC
          EPS_SCF 1.0E-6
          MAX_SCF 500
          ADDED_MOS 50
          CHOLESKY INVERSE
          &SMEAR ON
                  METHOD FERMI_DIRAC
                  ELECTRONIC_TEMPERATURE [K] 300
          &END SMEAR
          &DIAGONALIZATION
                  ALGORITHM STANDARD
          &END DIAGONALIZATION
          &MIXING
                METHOD BROYDEN_MIXING
                ALPHA 0.1
                BETA 1.5
                NBROYDEN 8
          &END MIXING
          &OUTER_SCF
                  EPS_SCF 1.0E-6
                  MAX_SCF 1
          &END OUTER_SCF
  &END SCF
  &XC
    ! use a PBE functional
    &XC_FUNCTIONAL
       &PBE
       &END
    &END XC_FUNCTIONAL
    ! adding Grimme's D3 correction (by default without C9 terms)
    &VDW_POTENTIAL
       POTENTIAL_TYPE PAIR_POTENTIAL
       &PAIR_POTENTIAL
          PARAMETER_FILE_NAME /global/homes/s/scorreal/CP2Kdata/dftd3.dat
          TYPE DFTD3
          REFERENCE_FUNCTIONAL PBE
          R_CUTOFF [angstrom] 3.8
       &END PAIR_POTENTIAL
    &END VDW_POTENTIAL
  &END XC
 &END DFT
 &SUBSYS
  &CELL
   ABC ${LA} ${LB} ${LC}
   ALPHA_BETA_GAMMA ${ALPHA} ${BETA} ${GAMMA}
   PERIODIC XYZ
  &END CELL
  &TOPOLOGY
    COORD_FILE_NAME ./${PREFIX}.xyz
    COORD_FILE_FORMAT XYZ
  &END
    &KIND H
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q1
    &END KIND
    &KIND O
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q6
    &END KIND
    &KIND S
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q6
    &END KIND
&END SUBSYS
STRESS_TENSOR ANALYTICAL
&END FORCE_EVAL
